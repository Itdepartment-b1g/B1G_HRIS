# Supabase Configuration
# Copy this file to .env and fill in your actual values

# Supabase Project URL
# Find this in: Supabase Dashboard > Settings > API > Project URL
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase Anon/Public Key
# Find this in: Supabase Dashboard > Settings > API > Project API keys > anon public
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Note: The Service Role Key is NOT stored here.
# It should be set as a Supabase secret for Edge Functions:
# Run: supabase secrets set SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
